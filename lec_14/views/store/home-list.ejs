<%- include('../partials/header') %>
<body>
    <%- include('../partials/nav') %>
    <main class="page-shell page-shell--simple">
        <h1>Home List</h1>
        
<section class="hero-section">
            <div>
                <p class="hero-section__eyebrow">Stay somewhere memorable</p>
                <h1>Registered homes here</h1>
                <p class="hero-section__text">
                    Browse comfortable stays with clear pricing, location details, and room to add your own property images.
                </p>
            </div>
        </section>

        <% if (registeredHouse.length === 0) { %>
            <section class="empty-state">
                <h2>No homes saved yet</h2>
        
            </section>
        <% } else { %>
            <section class="listing-grid">
                <% registeredHouse.forEach((homes, index) => { %>
                    <article class="listing-card">
                        <div class="listing-card__media">
                            <img src="<%= homes.image || '' %>" alt="<%= homes.houseName || 'Home image' %>" class="listing-card__image">
                        </div>

                        <div class="listing-card__content">
                            <p class="listing-card__label">Name</p>
                            <h2><%= homes.houseName || `Listing ${index + 1}` %></h2>

                            <p class="listing-card__label">Location</p>
                            <p class="listing-card__value"><%= homes.location || 'Location coming soon' %></p>

                            <p class="listing-card__label">Price</p>
                            <p class="listing-card__value">Rs. <%= homes.price || 'N/A' %></p>
                        <div class="btn_class">
                            <a href="/home-list/<%= homes.id %>" class="listing-card__btn">Details</a>
                           <%- include('../partials/fav',{details:homes}) %>
                        </div>
                        </div>
                    </article>
                <% }) %>
            </section>
      <%}%>


    </main>
</body>
</html>
